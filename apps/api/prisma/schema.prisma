generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  VOLUNTEER
  FAN
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(FAN)
  language     String   @default("en")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Incident {
  id          String @id @default(cuid())

  title       String
  description String
  location    String

  severity    IncidentSeverity
  status      IncidentStatus @default(OPEN)

  crowdDensity Int

  aiRisk       String?
  aiPriority   Int?
  aiSummary    String?
  aiActions    Json?
  aiResolution String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}