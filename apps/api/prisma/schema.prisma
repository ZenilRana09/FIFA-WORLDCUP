generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
  VOLUNTEER
  FAN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(FAN)
  language     String   @default("en")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}